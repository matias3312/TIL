generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// USUARIO
// ─────────────────────────────────────────
model User {
  id          String   @id @default(cuid())
  username    String   @unique
  email       String   @unique
  password    String
  bio         String?
  avatarUrl   String?
  createdAt   DateTime @default(now())

  posts       Post[]

  @@map("users")
}

// ─────────────────────────────────────────
// POST (el TIL del día)
// ─────────────────────────────────────────
model Post {
  id          String     @id @default(cuid())
  content     String     @db.VarChar(280)
  category    Category
  createdAt   DateTime   @default(now())

  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("posts")
}

// ─────────────────────────────────────────
// CATEGORÍAS disponibles
// ─────────────────────────────────────────
enum Category {
  TECNOLOGIA
  CIENCIA
  HISTORIA
  IDIOMAS
  MATEMATICAS
  ARTE
  SALUD
  NEGOCIOS
  OTRO
}